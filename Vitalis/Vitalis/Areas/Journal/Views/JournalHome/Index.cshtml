@using Microsoft.AspNetCore.Mvc.Rendering
@using Vitalis.Web.ViewModels
@model JournalEntryViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "Your Journal";
    var availableMeals = ViewBag.AvailableMeals as IEnumerable<MealViewModel> ?? Enumerable.Empty<MealViewModel>();
    var availableIngredients = ViewBag.AvailableIngredients as IEnumerable<IngredientViewModel> ?? Enumerable.Empty<IngredientViewModel>();
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <h1 class="body-header">Your Journal</h1>
    <div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">+ Add</button>
    </div>
</div>

@{
    double TotalFats = 0;
    double TotalCarbs = 0;
    double TotalProtein = 0;
}
<div class="row">
    <div class="col-12">
        <h3 class="body-header">Meals</h3>
        <table class="table" id="meals-table">
            <thead>
                <tr>
                    <th style="width:200px">Name</th>
                    <th style="width:120px">Amount</th>
                    <th></th>
                    <th class="text-end">Carbs</th>
                    <th class="text-end">Protein</th>
                    <th class="text-end">Fats</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Meals is null || !Model.Meals.Any(m => m.Selected))
                {
                    <tr><td colspan="5" class="text-muted">No meals in your journal.</td></tr>
                }
                else
                {
                    foreach (var meal in Model.Meals.Where(m => m.Selected))
                    {
                        var mc = 0.0; var mp = 0.0; var mf = 0.0;
                        if (meal.Ingredients is not null)
                        {
                            foreach (var ing in meal.Ingredients.Where(i => i.Selected))
                            {
                                mc += ing.Carbs * ing.Quantity / 100 * meal.Amount;
                                mp += ing.Protein * ing.Quantity / 100 * meal.Amount;
                                mf += ing.Fats * ing.Quantity / 100 * meal.Amount;
                            }
                        }
                        <tr data-meal-id="@meal.Id">
                            <td>@meal.Name</td>
                            <td class="text-end"><input form="@meal.Id" type="number" min="0" step="1" name="amount" class="form-control form-control-sm ing-qty" value="@meal.Amount" /></td>
                            <td class=" ing-fats" style="text-align:left">
                                <form asp-area="Journal" asp-controller="JournalHome" asp-action="UpdateAmount" method="post" id="@meal.Id" class="d-inline" style="text-align:left">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@meal.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary save-qty-btn invisible">Save</button>
                                </form>
                            </td>
                            <td class="text-end meal-carbs">@mc</td>
                            <td class="text-end meal-protein">@mp</td>
                            <td class="text-end meal-fats">@mf</td>
                            <td class="text-end">
                                <form asp-area="Journal" asp-controller="JournalHome" asp-action="RemoveFromJournal" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@meal.Id" />
                                    <input  type="hidden" name="MealOrIng" value="true" />
                                    <button type="submit" class="btn btn-sm btn-danger remove-meal">Remove</button>
                                </form>
                            </td>
                        </tr>
                        TotalFats += mf;
                        TotalCarbs += mc;
                        TotalProtein += mp;
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="col-12 mt-4">
        <h3 class="body-header">Ingredients</h3>
        <table class="table " id="ingredients-table">
            <thead>
                <tr>
                    <th style="width:200px">Name</th>
                    <th style="width:200px">Quantity (g)</th>   
                    <th class="text-end">Carbs</th>
                    <th class="text-end">Protein</th>
                    <th class="text-end">Fats</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Ingredients is null || !Model.Ingredients.Any(i => i.Selected))
                {
                    <tr><td colspan="6" class="text-muted">No ingredients in your journal.</td></tr>
                }
                else
                {
                    foreach (var ing in Model.Ingredients.Where(i => i.Selected))
                    {
                        <tr data-ingredient-id="@ing.IngredientId">
                            <td>@ing.IngredientName</td>
                            @Html.AntiForgeryToken()
                            <td style="text-align:left">
                                <form asp-area="Journal" asp-controller="JournalHome" asp-action="UpdateQuantity" method="post" id="ing.IngredientId+1" class="d-inline d-flex" style="text-align:left">
                                    @Html.AntiForgeryToken()
                                    <input type="number" min="0" step="0.1" name="quantity" class="form-control flex-fill mx-1 form-control-sm ing-qty" style="width:30%" value="@ing.Quantity" />
                                    <input type="hidden" name="id" value="@ing.IngredientId" />
                                    <button type="submit" class="btn flex-fill mx-1 btn-sm btn-primary save-qty-btn invisible">Save</button>
                                </form>
                            </td>
                            <td class="text-end ing-carbs">@(ing.Carbs * ing.Quantity / 100)</td>
                            <td class="text-end ing-protein">@(ing.Protein* ing.Quantity / 100)</td>
                            <td class="text-end ing-fats">@(ing.Fats* ing.Quantity / 100)</td>
                            <td class="text-end">
                                <form asp-area="Journal" asp-controller="JournalHome" asp-action="RemoveFromJournal" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@ing.IngredientId" />
                                    <input type="hidden" name="MealOrIng" value="false" />
                                    <button type="submit" class="btn btn-sm btn-danger remove-ingredient">Remove</button>
                                </form>
                            </td>
                        </tr>
                        TotalFats += ing.Fats * ing.Quantity / 100;
                        TotalCarbs += ing.Carbs * ing.Quantity / 100;
                        TotalProtein += ing.Protein * ing.Quantity / 100;
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="col-12 mt-4">
        <h4 class="body-text">Daily totals</h4>
        <div class="d-flex gap-3">
            <div class="p-3 border rounded body-text" style="text-align:center">Carbs: <strong id="daily-carbs">@TotalCarbs.ToString("F1")</strong></div>
            <div class="p-3 border rounded body-text" style="text-align:center">Protein: <strong id="daily-protein">@TotalProtein.ToString("F1")</strong></div>
            <div class="p-3 border rounded body-text" style="text-align:center">Fats: <strong id="daily-fats">@TotalFats.ToString("F1")</strong></div>
        </div>
    </div>
</div>

<!-- Add modal -->
<form asp-action="AddToJournal" method="post" class="row g-3" style="justify-content:center">
<div class="modal fade" id="addModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add to Journal</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <ul class="nav nav-tabs" id="addTab" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="meals-tab" data-bs-toggle="tab" data-bs-target="#meals-panel" type="button" role="tab">Meals</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="ingredients-tab" data-bs-toggle="tab" data-bs-target="#ingredients-panel" type="button" role="tab">Ingredients</button>
          </li>
        </ul>
        <div class="tab-content mt-3">
          <div class="tab-pane fade show active" id="meals-panel" role="tabpanel">
            <table class="table table-sm">
              <thead>
                <tr><th></th><th>Name</th></tr>
              </thead>
              <tbody>
                @{
                    var meals = Model.Meals.Where(m => m.Selected).ToList();
                }

                @for (int i =0; i<Model.Meals.Count(); i++)
                {
                    if (!Model.Meals[i].Selected)
                    {
                    <tr>
                        <td>
                            <input asp-for="@Model.Meals[i].Id" type="hidden" />
                            <input asp-for="@Model.Meals[i].Name" type="hidden" value="@Model.Meals[i].Name" />
                            <input asp-for="@Model.Meals[i].Selected" type="checkbox" class="avail-meal" data-id="@Model.Meals[i].Id" data-name="@Model.Meals[i].Name" />
                        </td>
                        <td>@Model.Meals[i].Name</td>
                    </tr>
                    }
                    else
                    {
                        <input asp-for="@Model.Meals[i].Id" type="hidden" />
                        <input asp-for="@Model.Meals[i].Name" type="hidden" value="@Model.Meals[i].Name" /> 
                        <input asp-for="@Model.Meals[i].Selected" type="hidden" value="@true" />
                    }
                }
              </tbody>
            </table>
          </div>
          <div class="tab-pane fade" id="ingredients-panel" role="tabpanel">
            <table class="table table-sm">
              <thead>
                <tr><th></th><th>Name</th><th style="width:120px">Quantity (g)</th></tr>
              </thead>
              <tbody>
                @{ var ingredients = Model.Ingredients?.ToList() ?? new List<JournalIngredientViewModel>(); }

                @for (int i = 0; i < Model.Ingredients.Count(); i++)
                {
                    <input  asp-for="@Model.Ingredients[i].IngredientId" type="hidden" />
                    <input asp-for="@Model.Ingredients[i].IngredientName" type="hidden" />
                    @Html.AntiForgeryToken()
                    if (ingredients[i].Selected == true){
                        continue;}
                    <tr>
                        <td><input asp-for="@Model.Ingredients[i].Selected" type="checkbox" class="avail-ing" data-id="@Model.Ingredients[i].IngredientId" data-name="@Model.Ingredients[i].IngredientName" /></td>
                        <td>@Model.Ingredients[i].IngredientName</td>
                        <td><input type="number" class="form-control form-control-sm avail-ing-qty" value="100" data-id="@Model.Ingredients[i].Quantity" data-name="@Model.Ingredients[i].Quantity" /></td>
                    </tr>
                }
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-primary" id="add-selected">Add Selected</button>
      </div>
    </div>
  </div>
</div>
</form>



<script>
    (function(){
        function toNumber(v){ return Number((v||0)); }
        document.addEventListener('input', function(e){
            if(e.target && e.target.classList.contains('ing-qty')){
                const row = e.target.closest('tr');
                if (!row) return;
                const saveBtn = row.querySelector('.save-qty-btn');
                if (saveBtn) {
                    saveBtn.classList.remove('invisible');
                }
            }
        });
    })();
</script>
