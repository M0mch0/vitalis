@model IEnumerable<MealViewModel>
@if (!Model.Any())
{
    <h3 class="body-header">No meals yet.</h3>
    <div>
        <a class="btn btn-primary" asp-controller="Create" asp-action="Meal">
            + Add Meal
        </a>

    </div>
}
else
{

    <div>
        <h1 class="mb-0 body-header">Meals</h1>
        <a class="btn btn-view" asp-controller="Create" asp-action="Meal">
            + Add Meal
        </a>

    </div>
    <div class="row g-3">
        <form asp-action="Meals" method="get" class="mb-4" style="padding:1rem">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Search meals..." name="searchQuery" value="@ViewData["SearchQuery"]" />
                <button class="btn btn-outline-secondary" type="submit">Search</button>
            </div>
        </form>


        @foreach (MealViewModel meal in Model)
        {
            <div class="col-md-4 " style="aspect-ratio: 4/5; padding:2%">
                @if (!string.IsNullOrEmpty(meal.ImageUrl))
                {
                    <img src="@meal.ImageUrl" asp-append-version="true" onerror="this.onerror=null;this.src='/images/default.jpg';"  class="img-fluid rounded" alt="@meal.Name" style="object-fit : cover; width : 100%; height : 50%">
                }
                else
                {
                    <img src="~/images/default.jpg" asp-append-version="true" class="img-fluid rounded" alt="@meal.Name" style="object-fit : cover; width : 100%; height : 50%">
                   
                }
                <div class="info-border" style="height : 50%; margin-left:3%; margin-right:3%; position:relative">
                    <span class="body-text" style="border-bottom: 2px solid #7AE3ABFF;">@meal.Name</span>
                    <div style="text-align:center; width :  100%; display:flex; align-items:center">
                        @if (meal.Tags is null || !meal.Tags.Any(t => t.Selected == true))
                        {
                            <span class="body-text" style="font-size:1.2rem; flex:1">Tags: No tags listed</span>
                        }
                        else
                        {
                            var a = meal.Tags.Where(m => m.Selected == true).OrderBy(mi => mi.TagId).Select(mi => mi.Name);
                            var result = string.Join(", ", a);
                            <span class="body-text" style="font-size:1.2rem; flex:1">Tags: @result</span>
                        }
                    </div>
                    <div style="text-align:center; width :  100%; display:flex; align-items:center">
                        @if (meal.Ingredients is null || !meal.Ingredients.Any(t => t.Selected == true))
                        {
                            <span class="body-text" style="font-size:1.2rem; flex:1">Ingredients: No ingredients listed</span>
                        }
                        else
                        {
                            var a = meal.Ingredients.Where(m => m.Selected == true).OrderBy(mi => mi.IngredientId).Select(mi => mi.IngredientName);
                            var b = meal.Ingredients.Where(mi => mi.Selected == true).OrderBy(mi => mi.IngredientName).Select(mi => mi.Quantity);
                            var result = string.Join(", ", a.Zip(b, (x, y) => $"{x} ({y}g)"));
                            <span class="body-text" style="font-size:1.2rem; flex:1">Ingredients: @result</span>
                        }
                    </div>
                    <div style="text-align:center; width :  100%; position:absolute; bottom:0; padding: 1rem">
                        <div class="d-flex gap-2 justify-content-between">
                        <a class="btn btn-view flex-fill mx-1 text-center" asp-controller="Catalog" asp-action="ViewIngredient" asp-route-id="@meal.Id">
                            View
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="btn btn-edit flex-fill mx-1 text-center" asp-controller="Create" asp-action="Meal" asp-route-id="@meal.Id">
                                Edit
                            </a>
                            <form asp-controller="Catalog" asp-action="DeleteMeal" method="post" class="flex-fill mx-1 d-flex">
                                <input value="@meal.Id" type="hidden" name="id" />
                                <button type="submit" class="btn btn-delete w-100">Delete</button>
                            </form>
                        }
                    </div>
                    </div>
                </div>
                

            </div>
        }
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination">
                @if((int)ViewData["CurrentPage"] > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Meals" asp-route-pageNumber="@( (int)ViewData["CurrentPage"] - 1 )" asp-route-searchQuery="@ViewData["SearchQuery"]">Previous</a>
                    </li>
                }

                @for(int i = 1; i <= (int)ViewData["TotalPages"]; i++)
                {
                    <li class="page-item @(i == (int)ViewData["CurrentPage"] ? "active" : "")">
                        <a class="page-link" asp-action="Meals" asp-route-pageNumber="@i" asp-route-searchQuery="@ViewData["SearchQuery"]">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}