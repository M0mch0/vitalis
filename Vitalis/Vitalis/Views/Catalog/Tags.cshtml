@model IEnumerable<TagViewModel>
@if (!Model.Any())
{
    <h3 class="body-header">No tags yet.</h3>
    <div>
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-primary" asp-controller="Create" asp-action="Tag">
                + Add Tag
            </a>
        }
    </div>
}
else
{

    <div>
        <h1 class="mb-0 body-header">Tags</h1>
        <a class="btn btn-view" asp-controller="Create" asp-action="Tag">
            + Add Tag
        </a>

    </div>
    <div class="row g-3">
        @foreach (TagViewModel tag in Model)
        {
            <div class="col-md-4 " style="aspect-ratio: 1/1; padding:2%">
                @if (!string.IsNullOrEmpty(tag.ImageUrl))
                {
                    <img src="@tag.ImageUrl" asp-append-version="true" onerror="this.onerror=null;this.src='/images/default.jpg';"  class="img-fluid rounded" alt="@tag.Name" style="object-fit : cover; width : 100%; height : 65%">
                }
                else
                {
                    <img src="~/images/default.jpg" asp-append-version="true" class="img-fluid rounded" alt="@tag.Name" style="object-fit : cover; width : 100%; height : 65%">

                }
                <div class="info-border" style="height : 35%; margin-left:3%; margin-right:3%; position:relative">
                    <span class="body-text" style="border-bottom: 2px solid #7AE3ABFF;">@tag.Name</span>

                    <div style="position:absolute; bottom:0; left:0; right:0; padding:1rem">
                        <div class="d-flex gap-2 justify-content-between">
                            <a class="btn btn-view flex-fill mx-1 text-center" asp-controller="Catalog" asp-action="ViewTag" asp-route-id="@tag.Id">
                                View
                            </a>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-edit flex-fill mx-1 text-center" asp-controller="Create" asp-action="Tag" asp-route-id="@tag.Id">
                                    Edit
                                </a>
                                <form asp-controller="Catalog" asp-action="DeleteTag" method="post" class="flex-fill mx-1 d-flex">
                                    <input value="@tag.Id" type="hidden" name="id" />
                                    <button type="submit" class="btn btn-delete w-100">Delete</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}