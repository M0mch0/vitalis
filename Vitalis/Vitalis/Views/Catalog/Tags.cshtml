@model IEnumerable<Tag>
@if (!Model.Any())
{
    <p class="text-muted">No tags yet.</p>
    <div>
        <a class="btn btn-primary" asp-controller="Create" asp-action="Ingredient">
            + Add Tag
        </a>

    </div>
}
else
{
    
    <div>
        <h1 class="mb-0">Tags</h1>
        <a class="btn btn-primary" asp-controller="Create" asp-action="Tag">
            + Add Tag
        </a>

    </div>
    <div class="row g-3">
    @foreach(Tag tag in Model)
    {
        <div class="col-12 col-md-3">
            @if (!string.IsNullOrEmpty(tag.ImageUrl))
            {
                <div style="width : 300px; height : 200px">
                    <img src="@tag.ImageUrl" asp-append-version="true" class="img-fluid rounded hover-zoom" alt="@tag.Name" height="300" style="object-fit : cover; width : 100%; height : 100%">
                </div>
            }
            else
            {
                <div style="width : 300px; height : 200px">
                    <img src="~/images/default.jpg" asp-append-version="true" class="img-fluid rounded hover-zoom" alt="@tag.Name" height="300" style="object-fit : cover; width : 100%; height : 100%">
                </div>
            }   
            <div style="text-align:center;">

                <form asp-action="DeleteTag" method="post">
                <a class="btn btn-primary" asp-controller="Catalog" asp-action="Ingredients">
                @tag.Name
                </a>
                
                        <input value="@tag.Id" type="hidden" name="id" />
                        <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
            
        </div>
        }
    </div>
}