@model ViewTagViewModel
@if (Model.Ingredients is null || !Model.Ingredients.Any())
{
    <div>
        <h1 class="mb-0">Ingredients</h1>

    </div>
    <p class="text-muted">No ingredients yet.</p>
}
else
{
    <div>
        <h1 class="mb-0">Ingredients</h1>

    </div>
    <table class="table table-hover">
        <thead>
            <tr>
                <th style="width: 200px;">Name</th>
                <th style="width: 100px;">Carbohydrates</th>
                <th style="width: 100px;">Protein</th>
                <th style="width: 100px;">Fat</th>
                <th>Tags</th>
                <th style="width: 60px;"> </th>
            </tr>
        </thead>
        <tbody>
            @foreach (IngredientViewModel ing in Model.Ingredients.ToList())
            {
                <tr>
                    <td>@ing.Name</td>
                    <td>@ing.NutrientProfile.Carbohydrates</td>
                    <td>@ing.NutrientProfile.Protein</td>
                    <td>@ing.NutrientProfile.Fat</td>
                    @if(ing.Tags is null)
                    {
                        <td>No tags yet</td>
                    }
                    else 
                    {
                        <td>@String.Join(", ", ing.Tags.Select(t => t.Name))</td>
                    }
                        

                    <td style="text-align:center;">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false"> · · ·</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" asp-controller="Create" asp-action="Ingredient" asp-route-id="@ing.Id" style="height:50px; text-align:center; line-height:40px">
                                <i class="fas fa-list"></i> Edit
                            </a>
                            <div class="dropdown-divider"></div>
                            <form class="dropdown-item btn" asp-action="DeleteIngredient" method="post" style="height:50px; text-align:center">
                                <input value="@ing.Id" type="hidden" name="id"  />
                                <input value="@Model.Id" type="hidden" name="TagId" />
                                <button type="submit" class="btn">Delete</button>
                            </form>
                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
}
@if (Model.Meals is null || !Model.Meals.Any())
{
    <div>
        <h1 class="mb-0">Meals</h1>

    </div>
    <p class="text-muted">No meals yet.</p>
}
else
{
    <div>
        <h1 class="mb-0">Meals</h1>

    </div>
    <table class="table table-hover">
        <thead>
            <tr>
                <th style="width: 200px;">Name</th>
                <th>Ingredients</th>
                <th style="width: 60px;"> </th>
            </tr>
        </thead>
        <tbody>
            @foreach (MealViewModel b in Model.Meals.OrderBy(b => b.Name))
            {
                <tr>
                    <td>@b.Name</td>
                    @if (b.Ingredients is null)
                    {
                        <td>No ingredients listed</td>
                    }
                    else
                    {
                        var a = b.Ingredients.Where(i => i.Selected == true).OrderBy(mi => mi.IngredientName).Select(mi => mi.IngredientName);
                        var c = b.Ingredients.Where(mi => mi.Selected == true).OrderBy(mi => mi.IngredientName).Select(mi => mi.Quantity);
                        var result = string.Join(", ", a.Zip(c, (x, y) => $"{x} ({y}g)"));
                        <td>@result</td>
                    }

                    <td style="text-align:center;">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false"> · · ·</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item btn" asp-controller="Create" asp-action="Meal" asp-route-id="@b.Id" style="height:50px; text-align:center; line-height:40px">
                                Edit
                            </a>
                            <div class="dropdown-divider"></div>
                            <form class="dropdown-item btn" asp-action="DeleteMeal" method="post" style="height:50px; text-align:center">
                                <input value="@b.Id" type="hidden" name="id" />
                                <input value="@Model.Id" type="hidden" name="TagId" />
                                <button type="submit" class="btn">Delete</button>
                            </form>
                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
}