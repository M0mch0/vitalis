@model IEnumerable<IngredientViewModel>
@if (!Model.Any())
{
    <p class="text-muted">No ingredients yet.</p>
    <div>
        <a class="btn btn-primary" asp-controller="Create" asp-action="Ingredient">
            + Add Ingredient
        </a>

    </div>
}
else
{
    <div>
        <h1 class="mb-0">Ingredients</h1>
        <a class="btn btn-primary" asp-controller="Create" asp-action="Ingredient">
            + Add Ingredient
        </a>

    </div>
    <table class="table table-hover">
        <thead>
            <tr>
                <th style="width: 200px;">Name</th>
                <th style="width: 100px;">Carbohydrates</th>
                <th style="width: 100px;">Protein</th>
                <th style="width: 100px;">Fat</th>
                <th>Tags</th>
                <th style="width: 60px;"> </th>
            </tr>
        </thead>
        <tbody>
            @foreach (IngredientViewModel ing in Model.ToList())
            {
                <tr>
                    <td>@ing.Name</td>
                    <td>@ing.NutrientProfile.Carbohydrates</td>
                    <td>@ing.NutrientProfile.Protein</td>
                    <td>@ing.NutrientProfile.Fat</td>
                    @if(ing.Tags is null || !ing.Tags.Any())
                    {
                        <td>No tags yet</td>
                    }
                    else
                    {
                        <td>@String.Join(", ", ing.Tags.Select(t => t.Name))</td>
                    }
                    <td style="text-align:center;">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false"> · · ·</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item btn" asp-controller="Create" asp-action="Ingredient" asp-route-id="@ing.Id" style="height:50px; text-align:center; line-height:40px">
                                 Edit
                            </a>
                            <div class="dropdown-divider"></div>
                            <form class="dropdown-item btn" asp-action="DeleteIngredient" method="post" style="height:50px; text-align:center">
                                <input value="@ing.Id" type="hidden" name="id" />
                                <input value="Ingredients" type="hidden" name="PrevAction" />
                                <button type="submit" class="btn">Delete</button>
                            </form>
                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
}
