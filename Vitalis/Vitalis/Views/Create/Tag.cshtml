@using Microsoft.AspNetCore.Mvc.Rendering
@using Vitalis.ViewModels
@model Tag

@{
    ViewData["Title"] = "Create Meal";
}

@if (!string.IsNullOrEmpty(Model.Name))
{
    <h1 style="text-align: center">Edit Tag</h1>
}
else
{
    <h1 style="text-align: center">Create Tag</h1>
}
<form asp-action="Tag" method="post" class="row g-3">
    <div class="col-12 col-md-3">
        <input asp-for="Id" method="post" class="form-control" type="hidden"/>
        <input asp-for="Name" class="form-control" placeholder="Name" value="@Model.Name"/>
    </div>
    <div class="col-12 col-md-9">
        <input asp-for="ImageUrl" class="form-control" placeholder="Image Url" value="@Model.ImageUrl" />
    </div>

    <div style="text-align:center">
        <button type="submit" class="btn btn-success" style="width : 100px">Save</button>
        <a class="btn btn-secondary" asp-controller="Catalog" asp-action="Tags" style="width : 100px">Cancel</a>
    </div>
</form>
